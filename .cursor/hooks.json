{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/format-cpp.sh"
      }
    ],
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/block-dangerous.sh",
        "timeout": 5
      }
    ],
    "beforeReadFile": [
      {
        "command": ".cursor/hooks/protect-secrets.sh",
        "timeout": 5
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/check-docs-sync.sh",
        "timeout": 15,
        "loop_limit": 1
      }
    ]
  }
}
